from fastapi.testclient import TestClient

from main import app


client = TestClient(app)


def test_{{ service_id | replace("-", "_") }}_requires_payment() -> None:
    response = client.{{ endpoint_method.lower() }}("{{ endpoint_path }}")
    assert response.status_code == 402


def test_{{ service_id | replace("-", "_") }}_accepts_mock_payment() -> None:
    response = client.{{ endpoint_method.lower() }}(
        "{{ endpoint_path }}",
        headers={"{{ mock_paid_header }}": "true"},
    )
    assert response.status_code in {200, 422}

